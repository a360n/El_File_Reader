<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EcoLAB EL File Reader & AI Dataset Auditor</title>
    
    <!-- Bootstrap 5 RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <!-- Google Cairo Font -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --accent-blue: #38bdf8;
            --accent-green: #22c55e;
            --accent-red: #ef4444;
            --accent-yellow: #f59e0b;
            --accent-orange: #f97316;
            --text-main: #f8fafc;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            min-height: 100vh;
        }

        .navbar-custom {
            background-color: rgba(30, 41, 59, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .card-custom {
            background-color: var(--card-bg);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }

        .btn-custom-green {
            background-color: var(--accent-green);
            color: #fff;
            border: none;
            font-weight: 700;
        }

        .btn-custom-green:hover {
            background-color: #16a34a;
            color: #fff;
        }

        .btn-custom-red {
            background-color: var(--accent-red);
            color: #fff;
            border: none;
            font-weight: 700;
        }

        .btn-custom-red:hover {
            background-color: #dc2626;
            color: #fff;
        }

        .btn-custom-blue {
            background-color: #0284c7;
            color: #fff;
            border: none;
            font-weight: 700;
        }

        .btn-custom-blue:hover {
            background-color: #0369a1;
            color: #fff;
        }

        .img-container {
            position: relative;
            width: 100%;
            height: 380px;
            background-color: #020617;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .img-container img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            transition: transform 0.3s ease;
        }

        .img-container img:hover {
            transform: scale(1.15);
            cursor: zoom-in;
        }

        .badge-pass {
            background-color: rgba(34, 197, 94, 0.2);
            color: #4ade80;
            border: 1px solid #22c55e;
        }

        .badge-fail {
            background-color: rgba(239, 68, 68, 0.2);
            color: #f87171;
            border: 1px solid #ef4444;
        }

        .table-custom {
            color: var(--text-main);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .table-custom th {
            background-color: #0f172a;
            color: var(--accent-blue);
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
        }

        .table-custom td {
            background-color: var(--card-bg);
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom sticky-top py-3">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center gap-3 text-white fw-bold" href="/Audit/Index">
                <i class="fa-solid fa-microchip text-info fs-3"></i>
                <span>قارئ EcoLAB EL وتدقيق بيانات الذكاء الاصطناعي</span>
            </a>

            <div class="d-flex align-items-center gap-3">
                <a href="/Audit/DefectivePanels" class="btn btn-outline-danger rounded-3 px-3 fw-bold" title="الانتقال لصفحة الألواح المعيبة فقط (تخطي الألواح السليمة)">
                    <i class="fa-solid fa-triangle-exclamation me-1"></i>الألواح المعيبة فقط
                </a>
                @RenderSection("HeaderActions", required: false)
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4 py-4">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
